<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.buddy.premarket</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/YOUR_USERNAME/workspaces/buddy/core/scripts/buddy-core-premarket.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <!-- NY 08:30 (EDT Local Time -> Sydney 22:30) -->
        <key>Hour</key>
        <integer>22</integer>
        <key>Minute</key>
        <integer>32</integer>
    </dict>
</dict>
</plist>
