# ==============================================================================
# Core Environment Configuration Template
# Copy this file to '.env' and fill in your details before running the pipeline.
# ==============================================================================

# (Required) Gemini API Key for translation and CIO commentary synthesis
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Fallback Gemini/Gemma models chain (comma-separated, ordered by preference)
# Default: gemma-4-31b,gemma-4-26b,gemma-3-27b,gemma-2-27b-it
# TRANSLATOR_MODEL=gemma-4-31b,gemma-4-26b

# (Optional) Oracle Cloud IP Address for pulling news feed JSON
ORACLE_IP_ADDRESS=[IP_ADDRESS]

# (Optional) Absolute path to the Oracle SSH private key
ORACLE_SSH_KEY=~/.ssh/oracle-cloud-ssh.key

# (Optional) Local Ollama model name for deterministic extraction fallback
# Default: llama3.1
# OLLAMA_MODEL=llama3.1

# (Optional) Enable git push for publishing reports
# Default: false
ENABLE_GIT_PUSH=false
